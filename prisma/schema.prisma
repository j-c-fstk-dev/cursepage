generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  isAuthorized Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Lesson {
  id             String @id @default(cuid())
  title          String
  description    String
  youtubeVideoId String
  orderIndex     Int    @unique
}
